# Tolerate peer-dependency conflicts during install.
# The Cloudflare Pages build runs `npx @cloudflare/next-on-pages@1`, which pulls
# the latest wrangler. wrangler >=4.108 requires @cloudflare/workers-types v5,
# while next-on-pages still declares a v4 peer — npm's strict resolver rejects
# this (ERESOLVE) even though the deps are types-only/optional. legacy-peer-deps
# makes the install proceed, unblocking the build.
legacy-peer-deps=true
